{
  "family": "shopease-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam:: 209197638095:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "shopease-container",
      "image": " 209197638095.dkr.ecr.us-east-1.amazonaws.com/shopease-repo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DB_HOST",
          "value": " shopease-db.cpkm40caotv5.us-east-2.rds.amazonaws.com"
        },
        {
          "name": "DB_NAME",
          "value": "shopease-db"
        }
      ]
    }
  ]
}
